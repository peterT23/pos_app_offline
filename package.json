{
  "name": "pos_offline",
  "version": "0.1.0",
  "description": "POS Offline Electron app",
  "author": "POS Offline Team",
  "private": true,
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "concurrently -k \"vite --port 5188\" \"wait-on tcp:5188 && POS_OFFLINE_NO_DEVTOOLS=1 electron .\"",
    "build:renderer": "vite build",
    "build": "npm run build:renderer",
    "dist:dir": "npm run build:renderer && electron-builder --dir",
    "dist:mac": "npm run build:renderer && electron-builder --mac dmg zip",
    "dist:win": "npm run build:renderer && electron-builder --win nsis portable",
    "dist:all": "npm run build:renderer && electron-builder -mwl",
    "lint": "echo \"no lint yet\"",
    "postinstall": "electron-rebuild -f -w better-sqlite3"
  },
  "dependencies": {
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@mui/icons-material": "^7.3.7",
    "@mui/material": "^7.3.7",
    "better-sqlite3": "^11.8.1",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-router-dom": "^7.12.0",
    "uuid": "^13.0.0",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@electron/rebuild": "^4.0.4",
    "@vitejs/plugin-react": "^5.1.1",
    "concurrently": "^9.1.2",
    "electron": "^35.0.0",
    "electron-builder": "^26.0.12",
    "vite": "^7.2.4",
    "wait-on": "^8.0.1"
  },
  "build": {
    "appId": "com.posoffline.app",
    "productName": "POS Offline",
    "asar": true,
    "npmRebuild": false,
    "asarUnpack": [
      "**/*.node"
    ],
    "directories": {
      "output": "release"
    },
    "files": [
      "electron/**/*",
      "dist/renderer/**/*",
      "package.json"
    ],
    "extraMetadata": {
      "main": "electron/main.cjs"
    },
    "mac": {
      "icon": "build/icon-source.png",
      "target": [
        "dmg",
        "zip"
      ],
      "category": "public.app-category.business"
    },
    "win": {
      "icon": "build/icon.ico",
      "target": [
        "nsis",
        "portable"
      ]
    },
    "linux": {
      "icon": "build/icon.png",
      "target": [
        "AppImage",
        "deb"
      ],
      "category": "Office"
    }
  }
}
